  "keyFeatures": [
    "Type-safe schema builder with strong TypeScript typing",
    "Type-safe data serialization and transformation",
    "Shared custom value transformers and formatters",
    "Column summaries with computed values",
    "Complex row structures with auto-merging",
    "Dynamic column selection and mapping",
    "Dynamic cell styling and formatting",
    "Multi-sheet and multi-table support",
    "Grid and linear layouts for tables"
  ],
  "publicApiSurface": [
    "ExcelSchemaBuilder.create<T>()",
    "ExcelSchemaBuilder.withTransformers()",
    "ExcelSchemaBuilder.withFormatters()",
    "ExcelSchemaBuilder.column()",
    "ExcelSchemaBuilder.group()",
    "ExcelSchemaBuilder.build()",
    "ExcelBuilder.create()",
    "ExcelBuilder.sheet()",
    "ExcelBuilder.addTable()",
